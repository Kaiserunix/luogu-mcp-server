{
  "name": "luogu-mcp-server",
  "version": "0.2.0",
  "description": "A stdio MCP server for searching and fetching Luogu problems and training sets.",
  "type": "module",
  "bin": {
    "luogu-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "smoke:live": "npm run build && node scripts/live-smoke.mjs",
    "smoke:topics": "npm run build && node scripts/topic-coverage-smoke.mjs",
    "smoke:mimo": "npm run build && node scripts/mimo-mcp-smoke.mjs",
    "download:topics": "npm run build && node scripts/download-topic-problems.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "luogu",
    "mcp",
    "model-context-protocol",
    "competitive-programming",
    "online-judge"
  ],
  "author": "Kaiserunix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiserunix/luogu-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/kaiserunix/luogu-mcp-server/issues"
  },
  "homepage": "https://github.com/kaiserunix/luogu-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
